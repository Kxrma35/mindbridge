rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    match /contacts/{docId} {
      allow read: if request.auth.uid == resource.data.ownerUid;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth.uid == resource.data.ownerUid;
    }

    match /signals/{docId} {
      allow create: if request.auth.uid == request.resource.data.fromUid;
      allow read: if request.auth.uid == resource.data.fromUid
                  || request.auth.uid == resource.data.toUid;
      allow update: if request.auth.uid == resource.data.toUid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /conversations/{convId} {
      // Allow if user is a participant — works for both existing and new docs
      allow read, write: if request.auth != null
                         && convId.split('_').hasAll([request.auth.uid]);

      match /messages/{msgId} {
        allow read: if request.auth != null
                    && convId.split('_').hasAll([request.auth.uid]);
        allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.senderUid
                      && convId.split('_').hasAll([request.auth.uid]);
      }
    }

    match /recovery/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
  }
}
