rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // Contacts belong to the owner
    match /contacts/{docId} {
      allow read, write: if request.auth.uid == resource.data.ownerUid
                         || request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth.uid == resource.data.ownerUid;
    }

    // Signals: sender can create, recipient can read and mark read
    match /signals/{docId} {
      allow create: if request.auth.uid == request.resource.data.fromUid;
      allow read:   if request.auth.uid == resource.data.fromUid
                    || request.auth.uid == resource.data.toUid;
      allow update: if request.auth.uid == resource.data.toUid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // Conversations: only participants can read/write
    match /conversations/{convId} {
      allow read, write: if request.auth.uid in resource.data.participants
                         || convId.split('_').hasAll([request.auth.uid]);

      match /messages/{msgId} {
        allow read:   if convId.split('_').hasAll([request.auth.uid]);
        allow create: if request.auth.uid == request.resource.data.senderUid
                      && convId.split('_').hasAll([request.auth.uid]);
      }
    }

    // Recovery data: only the owner
    match /recovery/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
  }
}
